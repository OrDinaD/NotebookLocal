# Paths
RAG_DATA_DIR=./data
RAG_DB_DIR=./data/lancedb
RAG_UPLOAD_DIR=./sample_data/uploads
RAG_EXTRACT_DIR=./data/extracted

# Models (local-only)
RAG_CHAT_MODEL=llama3.1:8b
RAG_VISION_MODEL=llava:13b
RAG_EMBED_MODEL=nomic-embed-text
RAG_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Runtime
RAG_TOP_K=5
RAG_MAX_CONTEXT_MESSAGES=10
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_LOG_LEVEL=INFO
