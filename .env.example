# Paths
RAG_DATA_DIR=./data
RAG_DB_DIR=./data/lancedb
RAG_UPLOAD_DIR=./sample_data/uploads
RAG_EXTRACT_DIR=./data/extracted

# Model provider (local-only): lmstudio or ollama
RAG_MODEL_PROVIDER=lmstudio
RAG_MODEL_ENDPOINT=http://127.0.0.1:1234
RAG_MODEL_API_KEY=lm-studio

# Models
RAG_CHAT_MODEL=google/gemma-4-e4b
RAG_VISION_MODEL=google/gemma-4-e4b
RAG_EMBED_MODEL=nomic-embed-text
RAG_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
RAG_USE_DOCLING=0

# Runtime
RAG_TOP_K=5
RAG_MAX_CONTEXT_MESSAGES=10
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_LOG_LEVEL=INFO
